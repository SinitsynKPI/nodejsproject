<!DOCTYPE html>
<html>
<head>
    <title>Admin Control Panel</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #f2f2f2; }
        .delete-btn { background: #ff4444; color: white; border: none; padding: 5px 10px; cursor: pointer; border-radius: 4px; }
    </style>
</head>
<body>
    <h1>Admin User Management</h1>
    <a href="/users/logout">Logout</a> | <a href="/users/login">Home</a>
    <hr>

    <table>
        <thead>
            <tr>
                <th>Email</th>
                <th>Role</th>
                <th>ID</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.email %></td>
                    <td><%= user.role %></td>
                    <td><%= user._id %></td>
                    <td>
                        <form action="/users/delete/<%= user._id %>?role=admin" method="POST" onsubmit="return confirm('Are you sure?')">
                            <button type="submit" class="delete-btn">Delete User</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>